<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DJ Max Respect V - Rhythm Game</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            color: #fff;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 900px;
        }

        /* Menu Styles */
        .menu {
            text-align: center;
            animation: slideIn 0.5s ease-out;
        }

        .menu h1 {
            font-size: 3em;
            margin-bottom: 10px;
            background: linear-gradient(45deg, #00d4ff, #7c3aed);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .menu p {
            font-size: 1.2em;
            color: #aaa;
            margin-bottom: 40px;
        }

        .stage-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .stage-btn {
            padding: 30px 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: 2px solid #7c3aed;
            color: white;
            font-size: 1.1em;
            font-weight: bold;
            cursor: pointer;
            border-radius: 10px;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .stage-btn:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(124, 58, 237, 0.5);
        }

        .stage-btn:active {
            transform: translateY(-2px);
        }

        .stage-difficulty {
            font-size: 0.8em;
            opacity: 0.8;
            margin-top: 5px;
        }

        .settings-btn {
            padding: 15px 40px;
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            border: none;
            color: white;
            font-size: 1em;
            font-weight: bold;
            cursor: pointer;
            border-radius: 5px;
            transition: all 0.3s;
            margin-top: 20px;
        }

        .settings-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 20px rgba(245, 87, 108, 0.4);
        }

        /* Settings Modal */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7);
            animation: fadeIn 0.3s;
        }

        .modal.active {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            padding: 30px;
            border-radius: 15px;
            max-width: 500px;
            width: 90%;
            border: 2px solid #7c3aed;
            max-height: 80vh;
            overflow-y: auto;
            animation: slideIn 0.3s;
        }

        .modal-content h2 {
            margin-bottom: 20px;
            color: #00d4ff;
        }

        .setting-group {
            margin-bottom: 25px;
        }

        .setting-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
            color: #aaa;
        }

        .setting-group input[type="range"] {
            width: 100%;
            cursor: pointer;
        }

        .setting-group input[type="text"],
        .setting-group input[type="number"] {
            width: 100%;
            padding: 10px;
            background: #0f3460;
            border: 1px solid #7c3aed;
            color: #fff;
            border-radius: 5px;
            font-size: 1em;
        }

        .setting-value {
            display: inline-block;
            margin-left: 10px;
            color: #00d4ff;
            font-weight: bold;
        }

        .modal-buttons {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            margin-top: 20px;
        }

        .modal-btn {
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s;
        }

        .modal-btn.save {
            background: #00d4ff;
            color: #000;
        }

        .modal-btn.save:hover {
            background: #00e6ff;
        }

        .modal-btn.cancel {
            background: #666;
            color: #fff;
        }

        .modal-btn.cancel:hover {
            background: #888;
        }

        /* Game Screen */
        .game-screen {
            display: none;
        }

        .game-screen.active {
            display: block;
            animation: slideIn 0.3s;
        }

        .game-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding: 15px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 10px;
        }

        .game-title {
            font-size: 1.5em;
            color: #00d4ff;
        }

        .game-score {
            font-size: 1.3em;
            color: #00ff00;
        }

        .game-accuracy {
            font-size: 1.1em;
            color: #ffff00;
        }

        .game-container {
            position: relative;
            background: #0a0a0a;
            border: 3px solid #7c3aed;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
            min-height: 600px;
        }

        .lanes-container {
            display: flex;
            gap: 8px;
            height: 500px;
            position: relative;
            background: linear-gradient(to bottom, rgba(124, 58, 237, 0.1), rgba(0, 0, 0, 0.5));
            border-radius: 5px;
            overflow: hidden;
        }

        .lane {
            flex: 1;
            position: relative;
            border: 1px solid rgba(124, 58, 237, 0.3);
            background: rgba(0, 0, 0, 0.4);
        }

        .judge-line {
            position: absolute;
            bottom: 50px;
            width: 100%;
            height: 3px;
            background: linear-gradient(to right, transparent, #ffff00, transparent);
            box-shadow: 0 0 10px #ffff00;
            z-index: 10;
        }

        .judge-text {
            position: absolute;
            bottom: 30px;
            width: 100%;
            text-align: center;
            font-weight: bold;
            color: #ffff00;
            font-size: 0.8em;
            z-index: 10;
        }

        .tile {
            position: absolute;
            width: 100%;
            background: linear-gradient(135deg, #00d4ff, #7c3aed);
            border: 2px solid #00d4ff;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.1s;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: #000;
            font-size: 0.8em;
        }

        .tile.long {
            background: linear-gradient(135deg, #f093fb, #f5576c);
            border-color: #f5576c;
        }

        .tile.pressed {
            transform: scale(0.95);
            opacity: 0.7;
        }

        .tile.missed {
            background: #666;
            border-color: #888;
        }

        .judgment {
            position: absolute;
            font-weight: bold;
            font-size: 1.2em;
            pointer-events: none;
            animation: floatUp 0.8s ease-out forwards;
        }

        .judgment.perfect {
            color: #ffff00;
        }

        .judgment.great {
            color: #00ff00;
        }

        .judgment.good {
            color: #00d4ff;
        }

        .judgment.bad {
            color: #ff6600;
        }

        .judgment.miss {
            color: #ff0000;
        }

        .game-controls {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-bottom: 20px;
        }

        .game-btn {
            padding: 12px 30px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            font-size: 1em;
            transition: all 0.3s;
        }

        .game-btn.pause {
            background: #ffb700;
            color: #000;
        }

        .game-btn.pause:hover {
            background: #ffc500;
        }

        .game-btn.back {
            background: #666;
            color: #fff;
        }

        .game-btn.back:hover {
            background: #888;
        }

        /* Pause Menu */
        .pause-menu {
            display: none;
            position: fixed;
            z-index: 500;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
            justify-content: center;
            align-items: center;
        }

        .pause-menu.active {
            display: flex;
        }

        .pause-content {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            padding: 40px;
            border-radius: 15px;
            text-align: center;
            border: 2px solid #7c3aed;
            animation: slideIn 0.3s;
        }

        .pause-content h2 {
            font-size: 2em;
            margin-bottom: 30px;
            color: #00d4ff;
        }

        .pause-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-direction: column;
        }

        .pause-btn {
            padding: 15px 30px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            font-size: 1.1em;
            transition: all 0.3s;
        }

        .pause-btn.resume {
            background: #00d4ff;
            color: #000;
        }

        .pause-btn.resume:hover {
            background: #00e6ff;
        }

        .pause-btn.exit {
            background: #ff6b6b;
            color: #fff;
        }

        .pause-btn.exit:hover {
            background: #ff8787;
        }

        /* Results Screen */
        .results-screen {
            display: none;
            text-align: center;
            animation: slideIn 0.5s;
        }

        .results-screen.active {
            display: block;
        }

        .results-title {
            font-size: 2.5em;
            margin-bottom: 30px;
            background: linear-gradient(45deg, #00d4ff, #7c3aed);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .results-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat-box {
            background: rgba(124, 58, 237, 0.2);
            padding: 20px;
            border-radius: 10px;
            border: 2px solid #7c3aed;
        }

        .stat-label {
            color: #aaa;
            font-size: 0.9em;
            margin-bottom: 10px;
        }

        .stat-value {
            font-size: 2em;
            font-weight: bold;
            color: #00d4ff;
        }

        .results-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .results-btn {
            padding: 12px 30px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            font-size: 1em;
            transition: all 0.3s;
        }

        .results-btn.retry {
            background: #00d4ff;
            color: #000;
        }

        .results-btn.retry:hover {
            background: #00e6ff;
        }

        .results-btn.menu {
            background: #7c3aed;
            color: #fff;
        }

        .results-btn.menu:hover {
            background: #8d5aff;
        }

        /* Animations */
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        @keyframes floatUp {
            to {
                transform: translateY(-50px);
                opacity: 0;
            }
        }

        @keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.1);
            }
        }

        .tile.active {
            animation: pulse 0.3s;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .menu h1 {
                font-size: 2em;
            }

            .stage-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .modal-content {
                width: 95%;
            }

            .pause-content {
                width: 90%;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Menu Screen -->
        <div class="menu" id="menuScreen">
            <h1>DJ MAX RESPECT V</h1>
            <p>Rhythm Game</p>
            <div class="stage-grid" id="stageGrid"></div>
            <button class="settings-btn" onclick="openSettings()">⚙️ Settings</button>
        </div>

        <!-- Settings Modal -->
        <div class="modal" id="settingsModal">
            <div class="modal-content">
                <h2>Settings</h2>
                
                <div class="setting-group">
                    <label for="timingOffset">Timing Offset (ms): <span class="setting-value" id="timingValue">0</span></label>
                    <input type="range" id="timingOffset" min="-200" max="200" value="0" oninput="updateTimingValue(this.value)">
                    <small>Adjust when notes appear (negative = earlier, positive = later)</small>
                </div>

                <div class="setting-group">
                    <label for="judgeWindow">Judge Window (ms): <span class="setting-value" id="judgeValue">100</span></label>
                    <input type="range" id="judgeWindow" min="50" max="200" value="100" oninput="updateJudgeValue(this.value)">
                    <small>How lenient the timing detection is</small>
                </div>

                <div class="setting-group">
                    <label for="scrollSpeed">Scroll Speed: <span class="setting-value" id="speedValue">1.0x</span></label>
                    <input type="range" id="scrollSpeed" min="0.5" max="2" step="0.1" value="1" oninput="updateSpeedValue(this.value)">
                </div>

                <div class="setting-group">
                    <label for="musicVolume">Music Volume: <span class="setting-value" id="volumeValue">100%</span></label>
                    <input type="range" id="musicVolume" min="0" max="100" value="100" oninput="updateVolumeValue(this.value)">
                </div>

                <div class="setting-group">
                    <label>Key Bindings</label>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                        <div>
                            <label style="font-size: 0.9em; margin-bottom: 5px;">Lane 1 <span class="setting-value" id="key1Display">D</span></label>
                            <input type="text" id="key1" value="d" maxlength="1" onchange="updateKeyDisplay('key1')">
                        </div>
                        <div>
                            <label style="font-size: 0.9em; margin-bottom: 5px;">Lane 2 <span class="setting-value" id="key2Display">F</span></label>
                            <input type="text" id="key2" value="f" maxlength="1" onchange="updateKeyDisplay('key2')">
                        </div>
                        <div>
                            <label style="font-size: 0.9em; margin-bottom: 5px;">Lane 3 <span class="setting-value" id="key3Display">J</span></label>
                            <input type="text" id="key3" value="j" maxlength="1" onchange="updateKeyDisplay('key3')">
                        </div>
                        <div>
                            <label style="font-size: 0.9em; margin-bottom: 5px;">Lane 4 <span class="setting-value" id="key4Display">K</span></label>
                            <input type="text" id="key4" value="k" maxlength="1" onchange="updateKeyDisplay('key4')">
                        </div>
                    </div>
                </div>

                <div class="modal-buttons">
                    <button class="modal-btn cancel" onclick="closeSettings()">Cancel</button>
                    <button class="modal-btn save" onclick="saveSettings()">Save</button>
                </div>
            </div>
        </div>

        <!-- Game Screen -->
        <div class="game-screen" id="gameScreen">
            <div class="game-header">
                <div class="game-title" id="stageName">Stage 1</div>
                <div>
                    <div class="game-score">Score: <span id="scoreDisplay">0</span></div>
                    <div class="game-accuracy">Accuracy: <span id="accuracyDisplay">0%</span></div>
                </div>
            </div>

            <div class="game-container">
                <div class="lanes-container" id="lanesContainer">
                    <div class="lane" id="lane0"></div>
                    <div class="lane" id="lane1"></div>
                    <div class="lane" id="lane2"></div>
                    <div class="lane" id="lane3"></div>
                </div>
                <div class="judge-line"></div>
                <div class="judge-text">JUDGE LINE</div>
            </div>

            <div class="game-controls">
                <button class="game-btn pause" onclick="togglePause()">⏸ Pause</button>
                <button class="game-btn back" onclick="exitGame()">🔙 Back to Menu</button>
            </div>
        </div>

        <!-- Pause Menu -->
        <div class="pause-menu" id="pauseMenu">
            <div class="pause-content">
                <h2>PAUSED</h2>
                <div class="pause-buttons">
                    <button class="pause-btn resume" onclick="togglePause()">Resume</button>
                    <button class="pause-btn exit" onclick="exitGame()">Exit to Menu</button>
                </div>
            </div>
        </div>

        <!-- Results Screen -->
        <div class="results-screen" id="resultsScreen">
            <div class="results-title">RESULTS</div>
            
            <div class="results-stats">
                <div class="stat-box">
                    <div class="stat-label">Final Score</div>
                    <div class="stat-value" id="finalScore">0</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Accuracy</div>
                    <div class="stat-value" id="finalAccuracy">0%</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Perfects</div>
                    <div class="stat-value" id="perfects">0</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Greats</div>
                    <div class="stat-value" id="greats">0</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Goods</div>
                    <div class="stat-value" id="goods">0</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Bads</div>
                    <div class="stat-value" id="bads">0</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Misses</div>
                    <div class="stat-value" id="misses">0</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">Combo</div>
                    <div class="stat-value" id="maxCombo">0</div>
                </div>
            </div>

            <div class="results-buttons">
                <button class="results-btn retry" onclick="retryStage()">Retry Stage</button>
                <button class="results-btn menu" onclick="backToMenu()">Back to Menu</button>
            </div>
        </div>
    </div>

    <script src="game.js"></script>
</body>
</html>

